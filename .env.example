# Frontend Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri kendi ortamınıza göre düzenleyin
# cp .env.example .env

# Backend API Base URL
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
API_BASE_URL=http://localhost:8000

# API Connection Timeout (milisaniye)
# Sunucuya bağlanma için maksimum bekleme süresi
API_CONNECT_TIMEOUT_MS=10000

# API Receive Timeout (milisaniye)
# Sunucudan veri alma için maksimum bekleme süresi
API_RECEIVE_TIMEOUT_MS=8000